{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ninja",
            "type": "shell",
            "command": "ninja",
            "args": [
                "-C",
                "build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "meson setup",
            "type": "shell",
            "command": "meson setup build --wipe",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}