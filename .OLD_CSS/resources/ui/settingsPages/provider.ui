<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="GtkBox" id="provider_root">
    <property name="orientation">vertical</property>
    <property name="spacing">24</property>
    <style><class name="settings-provider"/></style>

    <!-- Management section -->
    <child>
      <object class="GtkBox" id="provider_manage_box">
        <property name="orientation">vertical</property>
        <property name="spacing">12</property>
        <style><class name="settings-provider-manage-section"/></style>

        <child>
          <object class="GtkLabel" id="provider_manage_label">
            <property name="label">Add Provider</property>
            <property name="halign">start</property>
            <style><class name="settings-provider-manage-label"/></style>
          </object>
        </child>

        <!-- M3U / Credentials toggle -->
        <child>
          <object class="GtkBox" id="provider_toggle_box">
            <property name="orientation">horizontal</property>
            <property name="homogeneous">true</property>
            <style><class name="provider-toggle-box"/></style>

            <child>
              <object class="GtkButton" id="provider_toggle_m3u">
                <property name="label">M3U</property>
                <style><class name="provider-toggle-btn"/></style>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="provider_toggle_credentials">
                <property name="label">Credentials</property>
                <style><class name="provider-toggle-btn"/></style>
              </object>
            </child>
          </object>
        </child>

        <!-- Input stack (M3U url or credentials fields) -->
        <child>
          <object class="GtkStack" id="provider_input_stack">

            <child>
              <object class="GtkBox" id="provider_m3u_box">
                <property name="orientation">vertical</property>
                <property name="spacing">8</property>
                <child>
                  <object class="GtkEntry" id="provider_m3u_entry">
                    <property name="placeholder-text">M3U URL</property>
                    <style><class name="provider-entry"/></style>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="GtkBox" id="provider_credentials_box">
                <property name="orientation">vertical</property>
                <property name="spacing">8</property>
                <child>
                  <object class="GtkEntry" id="provider_host_entry">
                    <property name="placeholder-text">Host URL</property>
                    <style><class name="provider-entry"/></style>
                  </object>
                </child>
                <child>
                  <object class="GtkEntry" id="provider_user_entry">
                    <property name="placeholder-text">Username</property>
                    <style><class name="provider-entry"/></style>
                  </object>
                </child>
                <child>
                  <object class="GtkEntry" id="provider_pass_entry">
                    <property name="placeholder-text">Password</property>
                    <property name="visibility">false</property>
                    <style><class name="provider-entry"/></style>
                  </object>
                </child>
              </object>
            </child>

          </object>
        </child>

        <child>
          <object class="GtkButton" id="provider_add_btn">
            <property name="label">Add Provider</property>
            <property name="halign">end</property>
            <style><class name="provider-add-btn"/></style>
          </object>
        </child>

      </object>
    </child>

    <!-- Provider list -->
    <child>
      <object class="GtkBox" id="provider_list_wrapper">
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <style><class name="settings-provider-list-wrapper"/></style>

        <child>
          <object class="GtkLabel" id="provider_list_title">
            <property name="label">SAVED PROVIDERS</property>
            <property name="halign">start</property>
            <style><class name="settings-provider-list-title"/></style>
          </object>
        </child>

        <child>
          <object class="GtkBox" id="provider_list_box">
            <property name="orientation">vertical</property>
            <style><class name="provider-list"/></style>
          </object>
        </child>

      </object>
    </child>

  </object>
</interface>